---
interface Props {
  title: string;
  subtitle?: string;
  label?: string;
  image?: string;
  breadcrumb?: { label: string; href: string }[];
}

const {
  title,
  subtitle,
  label,
  image = 'https://images.unsplash.com/photo-1560518883-ce09059eeffa?w=1400&q=80',
  breadcrumb = [],
} = Astro.props;
---

<section class="relative overflow-hidden" style="min-height: 340px;">
  <!-- Image de fond -->
  <img
    src={image}
    alt={title}
    class="absolute inset-0 w-full h-full object-cover"
    loading="eager"
  />
  <!-- Overlay navy -->
  <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(10,15,30,0.88) 0%, rgba(13,26,58,0.80) 100%);"></div>

  <div class="relative max-w-8xl mx-auto px-4 sm:px-6 py-16 flex flex-col justify-center" style="min-height: 340px;">
    <!-- Breadcrumb -->
    {breadcrumb.length > 0 && (
      <nav class="mb-5 flex items-center gap-2 text-xs text-white/50" aria-label="Fil d'Ariane">
        <a href="/" class="hover:text-white transition-colors">Accueil</a>
        {breadcrumb.map(crumb => (
          <>
            <span>/</span>
            <a href={crumb.href} class="hover:text-white transition-colors">{crumb.label}</a>
          </>
        ))}
      </nav>
    )}

    {label && <span class="section-label text-xs mb-3" style="color: #00e5ff;">{label}</span>}

    <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white leading-tight max-w-2xl">
      {title}
    </h1>

    {subtitle && (
      <p class="mt-4 text-base sm:text-lg max-w-xl leading-relaxed" style="color: rgba(255,255,255,0.7);">
        {subtitle}
      </p>
    )}
  </div>
</section>
