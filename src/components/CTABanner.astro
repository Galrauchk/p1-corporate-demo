---
interface Props {
  title?: string;
  subtitle?: string;
  cta?: { label: string; href: string };
  ctaSecondary?: { label: string; href: string };
}

const {
  title = "Votre bien estimé en 48h, gratuitement",
  subtitle = "Sans engagement, sans frais. Nos agents vous remettent une estimation argumentée basée sur les ventes comparables de votre quartier.",
  cta = { label: "Demander mon estimation", href: "/estimation" },
  ctaSecondary = { label: "Nous appeler", href: "tel:0467000000" },
} = Astro.props;
---

<section style="background: #0d1a3a;" class="relative overflow-hidden">
  <!-- Deco -->
  <div class="absolute top-0 right-0 w-80 h-80 rounded-full blur-3xl opacity-10" style="background: #00e5ff;"></div>
  <div class="absolute bottom-0 left-0 w-64 h-64 rounded-full blur-3xl opacity-8" style="background: #0066ff;"></div>

  <div class="relative max-w-8xl mx-auto px-4 sm:px-6 py-16 text-center">
    <div class="fade-up">
      <span class="section-label" style="color: #00e5ff;">Offre gratuite</span>
      <h2 class="text-3xl sm:text-4xl font-bold text-white mt-2 mb-4">
        {title}
      </h2>
      <p class="text-gray-400 max-w-xl mx-auto mb-8 leading-relaxed">
        {subtitle}
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href={cta.href} class="btn-primary-pill">
          {cta.label}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href={ctaSecondary.href} class="btn-outline-cyan">
          {ctaSecondary.label}
        </a>
      </div>
    </div>
  </div>
</section>
