---
const year = new Date().getFullYear();
---

<footer style="background: #0a0f1e; color: #94a3b8;">

  <!-- Main grid -->
  <div class="max-w-8xl mx-auto px-4 sm:px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">

      <!-- Col 1 — Marque -->
      <div>
        <a href="/" class="flex items-center gap-2.5 mb-5">
          <div class="w-9 h-9 rounded-lg flex items-center justify-center" style="background: linear-gradient(135deg, #00e5ff, #0066ff);">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#0a0f1e" stroke-width="2.5">
              <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
          </div>
          <div class="leading-tight">
            <div class="text-base font-extrabold text-white tracking-tight">Nexus</div>
            <div class="text-xs font-semibold tracking-wide" style="color: #00e5ff;">IMMOBILIER</div>
          </div>
        </a>
        <p class="text-sm leading-relaxed mb-5">
          L'agence immobilière qui fait la différence à Montpellier, Nîmes et Sète depuis 15 ans.
        </p>
        <div class="flex items-center gap-3">
          {[
            { label: 'Facebook', href: '#', d: 'M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z' },
            { label: 'Instagram', href: '#', d: 'M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37zM17.5 6.5a1 1 0 110 2 1 1 0 010-2zM21 2H3a1 1 0 00-1 1v18a1 1 0 001 1h18a1 1 0 001-1V3a1 1 0 00-1-1z' },
            { label: 'LinkedIn', href: '#', d: 'M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-4 0v7h-4v-7a6 6 0 016-6zM2 9h4v12H2zm2-7a2 2 0 110 4 2 2 0 010-4z' },
          ].map(s => (
            <a href={s.href} aria-label={s.label} class="w-9 h-9 rounded-lg flex items-center justify-center transition-colors hover:text-white" style="background: rgba(255,255,255,0.07); color: #64748b;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d={s.d}/></svg>
            </a>
          ))}
        </div>
      </div>

      <!-- Col 2 — Services -->
      <div>
        <h3 class="text-xs font-bold uppercase tracking-widest text-white mb-5">Nos services</h3>
        <ul class="space-y-2.5">
          {[
            { label: 'Acheter un bien', href: '/acheter' },
            { label: 'Vendre votre bien', href: '/vendre' },
            { label: 'Location immobilière', href: '/louer' },
            { label: 'Gestion locative', href: '/gestion-locative' },
            { label: 'Estimation gratuite', href: '/estimation' },
            { label: 'Notre agence', href: '/notre-agence' },
          ].map(item => (
            <li>
              <a href={item.href} class="text-sm hover:text-white transition-colors flex items-center gap-2">
                <span style="color: #00e5ff;">›</span> {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 3 — Villes -->
      <div>
        <h3 class="text-xs font-bold uppercase tracking-widest text-white mb-5">Nos agences</h3>
        <ul class="space-y-4">
          {[
            { city: 'Montpellier', addr: '12 Rue de la Loge, 34000', tel: '04 67 00 00 00', href: '/montpellier' },
            { city: 'Nîmes', addr: '5 Bd Gambetta, 30000', tel: '04 66 00 00 00', href: '/nimes' },
            { city: 'Sète', addr: '8 Quai de la Marine, 34200', tel: '04 67 74 00 00', href: '/sete' },
          ].map(a => (
            <li>
              <a href={a.href} class="block hover:text-white transition-colors">
                <span class="text-sm font-semibold text-white">{a.city}</span>
                <span class="text-xs block mt-0.5">{a.addr}</span>
                <span class="text-xs block">{a.tel}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 4 — Newsletter -->
      <div>
        <h3 class="text-xs font-bold uppercase tracking-widest text-white mb-5">Alertes immo</h3>
        <p class="text-sm mb-4">Recevez les nouvelles annonces correspondant à votre projet.</p>
        <form onsubmit="return false;" class="flex flex-col gap-2">
          <input
            type="email"
            placeholder="votre@email.fr"
            class="px-4 py-3 rounded-lg text-sm text-gray-900 bg-white outline-none"
          />
          <button
            type="submit"
            class="px-4 py-3 rounded-lg text-sm font-bold text-navy transition-transform hover:-translate-y-0.5"
            style="background: linear-gradient(135deg, #00e5ff, #0066ff); color: #0a0f1e;"
          >
            Recevoir les alertes
          </button>
        </form>
        <p class="text-xs mt-3" style="color: #475569;">Désinscription possible à tout moment.</p>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t" style="border-color: rgba(255,255,255,0.07);">
    <div class="max-w-8xl mx-auto px-4 sm:px-6 py-5 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-xs" style="color: #475569;">
        © {year} Nexus Immobilier. Tous droits réservés. — Carte pro T n° CPI 3401 2018 000 012 345
      </p>
      <div class="flex items-center gap-5">
        {[
          { label: 'Mentions légales', href: '/mentions-legales' },
          { label: 'CGV', href: '/cgv' },
          { label: 'Confidentialité', href: '#' },
        ].map(item => (
          <a href={item.href} class="text-xs hover:text-gray-300 transition-colors" style="color: #475569;">{item.label}</a>
        ))}
      </div>
    </div>
  </div>
</footer>
