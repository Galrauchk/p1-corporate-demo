---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
---

<BaseLayout
  title="Estimation immobilière gratuite Montpellier — En 48h"
  description="Obtenez une estimation gratuite et précise de votre bien immobilier à Montpellier, Nîmes ou Sète. Rapport détaillé remis en 48h, sans engagement."
>
  <PageHero
    label="Estimation gratuite"
    title="Combien vaut votre bien aujourd'hui ?"
    subtitle="Estimation professionnelle et argumentée remise en 48h. Gratuite, sans visite imposée, sans engagement de vente."
    breadcrumb={[{ label: 'Estimation', href: '/estimation' }]}
    image="https://images.unsplash.com/photo-1554469384-e58fac16e23a?w=1400&q=80"
  />

  <!-- Méthode -->
  <section class="section-py bg-white">
    <div class="max-w-8xl mx-auto px-4 sm:px-6">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="fade-up">
          <span class="section-label">Notre méthode</span>
          <h2 class="text-3xl font-bold mt-1 mb-6" style="color: #0a0f1e;">Une estimation basée sur <span class="gradient-text">des données réelles</span></h2>
          <div class="space-y-5">
            {[
              { step: '1', title: 'Analyse comparative de marché', desc: "Nous étudions toutes les transactions réalisées dans votre rue et quartier sur les 12 derniers mois." },
              { step: '2', title: 'Caractéristiques intrinsèques', desc: "Surface, étage, exposition, état général, équipements, charges de copropriété sont intégrés dans notre calcul." },
              { step: '3', title: 'Tendances et projections', desc: "Dynamique du marché local, projets urbains, évolution de l'offre et de la demande sur votre secteur." },
              { step: '4', title: 'Rapport PDF détaillé', desc: "Vous recevez un document professionnel avec comparables, fourchette de prix et recommandations stratégiques." },
            ].map(s => (
              <div class="flex gap-4">
                <div class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0 text-sm font-extrabold" style="background: linear-gradient(135deg, #00e5ff, #0066ff); color: #0a0f1e;">{s.step}</div>
                <div>
                  <h3 class="font-semibold text-gray-900 mb-0.5">{s.title}</h3>
                  <p class="text-sm text-gray-500 leading-relaxed">{s.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Formulaire estimation -->
        <div class="fade-up delay-2">
          <div class="bg-white rounded-2xl border border-gray-200 shadow-xl p-8">
            <h3 class="text-xl font-bold mb-1" style="color: #0a0f1e;">Demander mon estimation</h3>
            <p class="text-sm text-gray-400 mb-6">Réponse sous 48h · Gratuit · Sans engagement</p>

            <form onsubmit="return false;" class="space-y-4">
              <div class="grid sm:grid-cols-2 gap-4">
                <div>
                  <label class="text-xs font-semibold text-gray-600 block mb-1.5">Type de bien *</label>
                  <select class="form-input">
                    <option>Appartement</option>
                    <option>Maison</option>
                    <option>Terrain</option>
                    <option>Local commercial</option>
                    <option>Immeuble</option>
                  </select>
                </div>
                <div>
                  <label class="text-xs font-semibold text-gray-600 block mb-1.5">Ville *</label>
                  <select class="form-input">
                    <option>Montpellier</option>
                    <option>Nîmes</option>
                    <option>Sète</option>
                    <option>Autre</option>
                  </select>
                </div>
              </div>

              <div>
                <label class="text-xs font-semibold text-gray-600 block mb-1.5">Adresse du bien *</label>
                <input type="text" class="form-input" placeholder="12 rue de la Paix, Montpellier" />
              </div>

              <div class="grid sm:grid-cols-2 gap-4">
                <div>
                  <label class="text-xs font-semibold text-gray-600 block mb-1.5">Surface (m²) *</label>
                  <input type="number" class="form-input" placeholder="75" />
                </div>
                <div>
                  <label class="text-xs font-semibold text-gray-600 block mb-1.5">Nombre de pièces</label>
                  <select class="form-input">
                    <option>1 pièce</option>
                    <option>2 pièces</option>
                    <option>3 pièces</option>
                    <option>4 pièces</option>
                    <option>5 pièces et +</option>
                  </select>
                </div>
              </div>

              <div class="grid sm:grid-cols-2 gap-4">
                <div>
                  <label class="text-xs font-semibold text-gray-600 block mb-1.5">Votre prénom *</label>
                  <input type="text" class="form-input" placeholder="Marie" />
                </div>
                <div>
                  <label class="text-xs font-semibold text-gray-600 block mb-1.5">Téléphone *</label>
                  <input type="tel" class="form-input" placeholder="06 XX XX XX XX" />
                </div>
              </div>

              <div>
                <label class="text-xs font-semibold text-gray-600 block mb-1.5">Email *</label>
                <input type="email" class="form-input" placeholder="vous@email.fr" />
              </div>

              <div>
                <label class="text-xs font-semibold text-gray-600 block mb-1.5">Informations complémentaires</label>
                <textarea class="form-input" rows="3" placeholder="Parking, cave, terrasse, état général…"></textarea>
              </div>

              <button type="submit" class="btn-primary w-full justify-center py-3.5">
                Recevoir mon estimation gratuite
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </button>
              <p class="text-xs text-gray-400 text-center">Vos données sont protégées — RGPD conforme</p>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Garanties -->
  <section style="background: #f8fafc;" class="section-py">
    <div class="max-w-8xl mx-auto px-4 sm:px-6">
      <div class="grid sm:grid-cols-3 gap-6">
        {[
          { icon: '🎁', title: '100% gratuit', desc: "Aucun frais, aucun engagement de vendre. L'estimation est un service offert par Nexus." },
          { icon: '⚡', title: 'Réponse en 48h', desc: "Votre rapport d'estimation vous est remis par email dans les 48h ouvrées suivant votre demande." },
          { icon: '📊', title: 'Rapport professionnel', desc: "Document PDF complet avec comparables de marché, analyse et recommandations de prix." },
        ].map((g, i) => (
          <div class={`fade-up delay-${i + 1} text-center p-6`}>
            <span class="text-4xl block mb-3">{g.icon}</span>
            <h3 class="font-bold text-gray-900 mb-2">{g.title}</h3>
            <p class="text-sm text-gray-500 leading-relaxed">{g.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
